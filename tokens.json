{
  "name": "Regina Martinelli Design System",
  "source": "https://www.reginamartinelli.com (Squarespace 7.1)",
  "color": {
    "primary":      { "value": "#642875", "hsl": "286.75, 49.04%, 30.78%", "use": "Primary text and dark UI" },
    "accent":       { "value": "#A86DDF", "hsl": "271.05, 64.04%, 65.1%",  "use": "Buttons, links, highlights" },
    "lightAccent":  { "value": "#F5A6E4", "hsl": "312.91, 79.8%, 80.59%",  "use": "Soft backgrounds, gentle accents" },
    "darkAccent":   { "value": "#290033", "hsl": "288.24, 100%, 10%",      "use": "Deep contrast sections" },
    "white":        { "value": "#FFFFFF", "hsl": "0, 0%, 100%",            "use": "Backgrounds" },
    "gold":         { "value": "#C6A24B", "hsl": "44, 50%, 53%",           "use": "Logo / sacred-geometry motif accent" }
  },
  "typography": {
    "fontHeading": {
      "family": "orpheus-pro",
      "fallback": "Georgia, 'Times New Roman', serif",
      "source": "Adobe Fonts (Typekit)",
      "weight": 400,
      "lineHeight": 1.4,
      "letterSpacing": "0em",
      "textTransform": "none"
    },
    "fontBody": {
      "family": "Inter Tight",
      "fallback": "'Helvetica Neue', Helvetica, Arial, sans-serif",
      "source": "Google Fonts",
      "weights": [400, 500, 700],
      "lineHeight": 1.84,
      "letterSpacing": "0em"
    },
    "scale": {
      "h1": { "size": "6.5rem", "fluid": "clamp(2.75rem, 6vw + 1rem, 6.5rem)" },
      "h2": { "size": "4.2rem", "fluid": "clamp(2.1rem, 4vw + 0.75rem, 4.2rem)" },
      "h3": { "size": "2.9rem", "fluid": "clamp(1.6rem, 2vw + 0.75rem, 2.9rem)" },
      "h4": { "size": "2rem",   "fluid": "clamp(1.25rem, 1vw + 0.75rem, 2rem)" },
      "body": { "size": "1.125rem" }
    }
  },
  "spacing": {
    "xs": "0.5rem",
    "sm": "1rem",
    "md": "2rem",
    "lg": "4rem",
    "xl": "8rem",
    "sectionPaddingY": "6rem",
    "contentMaxWidth": "1200px"
  },
  "radius": {
    "button": "6.8px",
    "card": "12px",
    "pill": "999px"
  },
  "buttons": {
    "primary": {
      "fontFamily": "Inter Tight",
      "fontSize": "1.23rem",
      "fontWeight": 500,
      "lineHeight": 1.22,
      "padding": "1.5rem 2.2rem",
      "borderRadius": "6.8px",
      "background": "#A86DDF",
      "color": "#FFFFFF"
    },
    "secondary": {
      "fontFamily": "Inter Tight",
      "fontSize": "1.47rem",
      "fontWeight": 500,
      "borderRadius": "6.8px",
      "background": "transparent",
      "color": "#642875",
      "border": "1.5px solid #642875"
    }
  }
}
